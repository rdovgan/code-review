# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_MAX_DIFF_TOKENS=8000

# Redis
REDIS_URL=redis://localhost:6379/0

# Review limits
MAX_DIFF_LINES=500
AI_DAILY_TOKEN_BUDGET=100000  # input+output tokens per day; 0 = unlimited

# Bitbucket credentials are stored per-workspace in config/credentials.yml
# See config/credentials.yml.example
