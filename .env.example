# AI provider: "claude" or "glm"
AI_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AI_MODEL=claude-sonnet-4-6

# GLM (Z.AI) — used when AI_PROVIDER=glm
ZAI_API_KEY=your-zai-api-key-here
# General API: https://api.z.ai/api/paas/v4
# Coding Plan: https://api.z.ai/api/coding/paas/v4
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM_MODEL=glm-5-turbo

AI_MAX_TOKENS=4096
AI_MAX_DIFF_TOKENS=8000

# Redis
REDIS_URL=redis://localhost:6379/0

# Review limits
MAX_DIFF_LINES=500
AI_DAILY_TOKEN_BUDGET=100000  # input+output tokens per day; 0 = unlimited

# Bitbucket credentials are stored per-workspace in config/credentials.yml
# See config/credentials.yml.example
