# Per-workspace Bitbucket credentials
# Copy this file to credentials.yml and fill in real values.
# credentials.yml is gitignored — never commit it.
#
# One entry per Bitbucket workspace (organization).
# The workspace key must match the first segment of the repo full name:
#   e.g. "myworkspace" for repo "myworkspace/my-service"
#
# How to create an App Password:
#   Bitbucket → Personal Settings → App passwords → Create app password
#   Required permissions: Repositories: Read | Pull requests: Read, Write
#
# How to get the webhook_secret:
#   Generate one with: openssl rand -hex 32
#   Use the same value when registering the webhook in Bitbucket.

bitbucket:
  workspaces:

    myworkspace:
      username: alice
      app_password: ATBBxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      webhook_secret: aabbccddeeff00112233445566778899aabbccddeeff00112233445566778899

    anotherorg:
      username: bob
      app_password: ATBByyyyyyyyyyyyyyyyyyyyyyyyyyyy
      webhook_secret: 1122334455667788990011223344556677889900112233445566778899001122

    thirdteam:
      username: serviceaccount
      app_password: ATBBzzzzzzzzzzzzzzzzzzzzzzzzzzzz
      webhook_secret: deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
