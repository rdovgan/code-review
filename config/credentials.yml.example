# Per-workspace and per-repository Bitbucket credentials
# Copy this file to credentials.yml and fill in real values.
# credentials.yml is gitignored — never commit it.
#
# Structure:
#   workspace  → username + app_password (one Bitbucket account per organization)
#   repository → webhook_secret          (each repo has its own webhook with its own secret)
#
# How to create an App Password (one per workspace):
#   Bitbucket → Personal Settings → App passwords → Create app password
#   Required permissions: Repositories: Read | Pull requests: Read, Write
#
# How to generate a webhook secret (one per repository):
#   openssl rand -hex 32
#   Use the same value when registering the webhook in that repository's settings.

bitbucket:
  workspaces:

    first-workspace:
      username: alice
      app_password: ATBBxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      repositories:
        backend-api:
          webhook_secret: aabbccddeeff00112233445566778899aabbccddeeff00112233445566778899
        frontend-app:
          webhook_secret: 1122334455667788990011223344556677889900112233445566778899001122

    second-workspace:
      username: bob
      app_password: ATBByyyyyyyyyyyyyyyyyyyyyyyyyyyy
      repositories:
        mobile-app:
          webhook_secret: deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
        data-service:
          webhook_secret: cafebabecafebabecafebabecafebabecafebabecafebabecafebabecafebabe

    third-workspace:
      username: serviceaccount
      app_password: ATBBzzzzzzzzzzzzzzzzzzzzzzzzzzzz
      repositories:
        legacy-monolith:
          webhook_secret: 0000111122223333444455556666777788889999aaaabbbbccccddddeeeeffff
