# Per-workspace and per-repository Bitbucket credentials
# Copy this file to credentials.yml and fill in real values.
# credentials.yml is gitignored — never commit it.
#
# Auth resolution order (first match wins):
#   1. api_token on the repository   ← Repository Access Token (per-repo)
#   2. api_token on the workspace    ← Workspace Access Token (covers all repos)
#   3. username + app_password       ← App Password (legacy, still supported)
#
# How to create a Repository Access Token:
#   Repository → Settings → Security → Access tokens → Create access token
#   Scopes: Repositories: Read | Pull requests: Read, Write
#
# How to generate a webhook secret (one per repository):
#   openssl rand -hex 32

bitbucket:
  workspaces:

    # Per-repo API tokens
    first-workspace:
      repositories:
        backend-api:
          api_token: ATBBxxxxxxxxxxxxxxxxxxxxxxxxxxxx
          webhook_secret: aabbccddeeff00112233445566778899aabbccddeeff00112233445566778899
        frontend-app:
          api_token: ATBByyyyyyyyyyyyyyyyyyyyyyyyyyyy
          webhook_secret: 1122334455667788990011223344556677889900112233445566778899001122

    # Workspace-level API token (covers all repos in the workspace)
    second-workspace:
      api_token: ATBBzzzzzzzzzzzzzzzzzzzzzzzzzzzz
      repositories:
        mobile-app:
          webhook_secret: deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
        data-service:
          webhook_secret: cafebabecafebabecafebabecafebabecafebabecafebabecafebabecafebabe

    # App Password (legacy)
    third-workspace:
      username: charlie
      app_password: ATBBaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      repositories:
        legacy-app:
          webhook_secret: 0000111122223333444455556666777788889999aaaabbbbccccddddeeeeffff
