{
  "title": "Code Review Bot",
  "uid": "code-review-bot",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Reviews Today",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(code_review_reviews_total[24h])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Webhooks Today",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(code_review_webhooks_total{status=\"queued\"}[24h])",
          "legendFormat": "queued"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Review Duration",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "ms"
      },
      "targets": [
        {
          "expr": "code_review_duration_milliseconds_sum / clamp_min(code_review_duration_milliseconds_count, 1)",
          "legendFormat": "avg ms"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical Findings Today",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "increase(code_review_findings_total{severity=\"critical\"}[24h])",
          "legendFormat": "critical"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reviews per Hour",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "increase(code_review_reviews_total[1h])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Webhook Requests per Hour",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "increase(code_review_webhooks_total[1h])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Findings by Severity (all time)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "code_review_findings_total",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Findings by Source",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "code_review_findings_by_source_total",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Review Outcomes",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "code_review_reviews_total",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
