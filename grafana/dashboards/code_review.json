{
  "title": "Code Review Bot",
  "uid": "code-review-bot",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Reviews Today",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "round(sum(increase(code_review_reviews_total{status!=\"skipped\"}[24h])))", "legendFormat": "reviewed" }]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Blocked Merges Today",
      "description": "PRs where critical issues were found and merge is blocked",
      "gridPos": { "x": 4, "y": 0, "w": 3, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
      },
      "targets": [{ "expr": "round(increase(code_review_reviews_total{status=\"failure\"}[24h]))", "legendFormat": "blocked" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Webhooks Today",
      "gridPos": { "x": 8, "y": 0, "w": 3, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "round(increase(code_review_webhooks_total{status=\"queued\"}[24h]))", "legendFormat": "queued" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Critical Findings Today",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "red", "value": 1 }] }
      },
      "targets": [{ "expr": "round(increase(code_review_findings_total{severity=\"critical\"}[24h]))", "legendFormat": "critical" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Review Duration",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] }, "unit": "ms" },
      "targets": [{ "expr": "code_review_duration_milliseconds_sum / clamp_min(code_review_duration_milliseconds_count, 1)", "legendFormat": "avg ms" }]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Avg Findings per Review",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 7 }] }
      },
      "targets": [{
        "expr": "round(sum(code_review_findings_total) / clamp_min(sum(code_review_reviews_total{status=\"success\"}), 1), 0.1)",
        "legendFormat": "findings/review"
      }]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Webhook Efficiency",
      "gridPos": { "x": 22, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percent",
        "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 20 }, { "color": "green", "value": 50 }] }
      },
      "targets": [{
        "expr": "round(code_review_webhooks_total{status=\"queued\"} / clamp_min(sum(code_review_webhooks_total), 1) * 100, 1)",
        "legendFormat": "% queued"
      }]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Reviews per Hour",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "increase(code_review_reviews_total{status!=\"skipped\"}[1h])", "legendFormat": "{{status}}" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Webhook Requests per Hour",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "increase(code_review_webhooks_total[1h])", "legendFormat": "{{status}}" }]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Review Duration Trend (rolling 30m avg)",
      "description": "Monitors if reviews are getting slower over time. Spike = Semgrep rule download or API slowdown.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" }, "unit": "s" },
      "targets": [{
        "expr": "rate(code_review_duration_milliseconds_sum[30m]) / clamp_min(rate(code_review_duration_milliseconds_count[30m]), 0.001) / 1000",
        "legendFormat": "avg duration (s)"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Findings by Severity (all time)",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "targets": [{ "expr": "code_review_findings_total{severity!=\"total\"}", "legendFormat": "{{severity}}" }]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Findings by Source",
      "gridPos": { "x": 18, "y": 12, "w": 3, "h": 8 },
      "targets": [{ "expr": "code_review_findings_by_source_total", "legendFormat": "{{source}}" }]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Review Outcomes",
      "gridPos": { "x": 21, "y": 12, "w": 3, "h": 8 },
      "targets": [{ "expr": "code_review_reviews_total{status!=\"skipped\"}", "legendFormat": "{{status}}" }]
    },

    {
      "id": 10,
      "type": "row",
      "title": "By Language",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "table",
      "title": "Language Summary",
      "description": "Reviews count and findings breakdown per language",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "options": { "sortBy": [{ "displayName": "Reviews", "desc": true }] },
      "transformations": [
        { "id": "joinByField", "options": { "byField": "language" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "__name__": true, "instance": true, "job": true, "severity": true, "status": true },
            "renameByName": {
              "language": "Language",
              "Value #A": "Reviews",
              "Value #B": "Critical",
              "Value #C": "Bug",
              "Value #D": "Performance",
              "Value #E": "Suggestion"
            }
          }
        }
      ],
      "targets": [
        { "expr": "sum by (language) (code_review_reviews_by_language_total{status!=\"skipped\"})", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_language_total{severity=\"critical\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_language_total{severity=\"bug\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_language_total{severity=\"performance\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_language_total{severity=\"suggestion\"}", "instant": true, "format": "table", "legendFormat": "" }
      ]
    },

    {
      "id": 13,
      "type": "row",
      "title": "By Project",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 14,
      "type": "table",
      "title": "Findings by Project",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 10 },
      "options": { "sortBy": [{ "displayName": "Critical", "desc": true }] },
      "transformations": [
        { "id": "joinByField", "options": { "byField": "project" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__": true, "instance": true, "job": true, "severity": true },
            "renameByName": {
              "project": "Project",
              "Value #A": "Critical",
              "Value #B": "Bug",
              "Value #C": "Performance",
              "Value #D": "Suggestion"
            }
          }
        }
      ],
      "targets": [
        { "expr": "code_review_findings_by_project_total{severity=\"critical\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_project_total{severity=\"bug\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_project_total{severity=\"performance\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_project_total{severity=\"suggestion\"}", "instant": true, "format": "table", "legendFormat": "" }
      ]
    },

    {
      "id": 16,
      "type": "row",
      "title": "By Author",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 17,
      "type": "table",
      "title": "Findings by Author",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 10 },
      "options": { "sortBy": [{ "displayName": "Critical", "desc": true }] },
      "transformations": [
        { "id": "joinByField", "options": { "byField": "author" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__": true, "instance": true, "job": true, "severity": true },
            "renameByName": {
              "author": "Author",
              "Value #A": "Critical",
              "Value #B": "Bug",
              "Value #C": "Performance",
              "Value #D": "Suggestion"
            }
          }
        }
      ],
      "targets": [
        { "expr": "code_review_findings_by_author_total{severity=\"critical\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_author_total{severity=\"bug\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_author_total{severity=\"performance\"}", "instant": true, "format": "table", "legendFormat": "" },
        { "expr": "code_review_findings_by_author_total{severity=\"suggestion\"}", "instant": true, "format": "table", "legendFormat": "" }
      ]
    }
  ]
}
