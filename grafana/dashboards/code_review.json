{
  "title": "Code Review Bot",
  "uid": "code-review-bot",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Reviews Today",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "increase(code_review_reviews_total[24h])", "legendFormat": "{{status}}" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Webhooks Today",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "increase(code_review_webhooks_total{status=\"queued\"}[24h])", "legendFormat": "queued" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Review Duration",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] }, "unit": "ms" },
      "targets": [{ "expr": "code_review_duration_milliseconds_sum / clamp_min(code_review_duration_milliseconds_count, 1)", "legendFormat": "avg ms" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical Findings Today",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
      },
      "targets": [{ "expr": "increase(code_review_findings_total{severity=\"critical\"}[24h])", "legendFormat": "critical" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reviews per Hour",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "increase(code_review_reviews_total[1h])", "legendFormat": "{{status}}" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Webhook Requests per Hour",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "increase(code_review_webhooks_total[1h])", "legendFormat": "{{status}}" }]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Findings by Severity (all time)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "code_review_findings_total", "legendFormat": "{{severity}}" }]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Findings by Source",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "targets": [{ "expr": "code_review_findings_by_source_total", "legendFormat": "{{source}}" }]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Review Outcomes",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "targets": [{ "expr": "code_review_reviews_total", "legendFormat": "{{status}}" }]
    },

    {
      "id": 10,
      "type": "row",
      "title": "By Language",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Reviews by Language",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "sum by (language) (code_review_reviews_by_language_total)", "legendFormat": "{{language}}" }]
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "Findings by Language",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "options": {
        "stacking": "normal",
        "legend": { "displayMode": "list" },
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "bug" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "performance" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
            { "matcher": { "id": "byName", "options": "suggestion" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
          ]
        }
      },
      "targets": [
        { "expr": "code_review_findings_by_language_total{severity=\"critical\"}", "legendFormat": "critical" },
        { "expr": "code_review_findings_by_language_total{severity=\"bug\"}", "legendFormat": "bug" },
        { "expr": "code_review_findings_by_language_total{severity=\"performance\"}", "legendFormat": "performance" },
        { "expr": "code_review_findings_by_language_total{severity=\"suggestion\"}", "legendFormat": "suggestion" }
      ]
    },

    {
      "id": 13,
      "type": "row",
      "title": "By Project",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 14,
      "type": "barchart",
      "title": "Reviews by Project",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "sum by (project) (code_review_reviews_by_project_total)", "legendFormat": "{{project}}" }]
    },
    {
      "id": 15,
      "type": "barchart",
      "title": "Findings by Project",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "options": {
        "stacking": "normal",
        "legend": { "displayMode": "list" },
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "critical" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "bug" },         "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "performance" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
            { "matcher": { "id": "byName", "options": "suggestion" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
          ]
        }
      },
      "targets": [
        { "expr": "code_review_findings_by_project_total{severity=\"critical\"}", "legendFormat": "critical" },
        { "expr": "code_review_findings_by_project_total{severity=\"bug\"}", "legendFormat": "bug" },
        { "expr": "code_review_findings_by_project_total{severity=\"performance\"}", "legendFormat": "performance" },
        { "expr": "code_review_findings_by_project_total{severity=\"suggestion\"}", "legendFormat": "suggestion" }
      ]
    },

    {
      "id": 16,
      "type": "row",
      "title": "By Author",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 17,
      "type": "barchart",
      "title": "Reviews by Author",
      "gridPos": { "x": 0, "y": 39, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [{ "expr": "sum by (author) (code_review_reviews_by_author_total)", "legendFormat": "{{author}}" }]
    },
    {
      "id": 18,
      "type": "barchart",
      "title": "Findings by Author",
      "gridPos": { "x": 12, "y": 39, "w": 12, "h": 8 },
      "options": {
        "stacking": "normal",
        "legend": { "displayMode": "list" },
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "critical" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "bug" },         "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "performance" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
            { "matcher": { "id": "byName", "options": "suggestion" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
          ]
        }
      },
      "targets": [
        { "expr": "code_review_findings_by_author_total{severity=\"critical\"}", "legendFormat": "critical" },
        { "expr": "code_review_findings_by_author_total{severity=\"bug\"}", "legendFormat": "bug" },
        { "expr": "code_review_findings_by_author_total{severity=\"performance\"}", "legendFormat": "performance" },
        { "expr": "code_review_findings_by_author_total{severity=\"suggestion\"}", "legendFormat": "suggestion" }
      ]
    }
  ]
}
